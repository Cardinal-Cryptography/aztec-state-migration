{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "critesjosh/aztec-claude-plugin": true
  },
  "permissions": {
    "allow": [
      "Bash(nargo *)",
      "Bash(aztec *)",
      "Bash(forge *)",
      "Bash(yarn test*)",
      "Bash(yarn build*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(yarn check:fast*)",
      "Bash(yarn check:full*)"
    ]
  }
}
