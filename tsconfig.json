{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true
  },
  "include": ["noir/artifacts/**/*", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
