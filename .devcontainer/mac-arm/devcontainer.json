{
  "name": "Development (Mac ARM / Rosetta)",
  "build": {
    "context": "../development",
    "dockerfile": "../development/Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=${localEnv:HOME}/.claude,type=bind,consistency=cached"
  ],
  "postCreateCommand": "bash .devcontainer/mac-arm/postCreate.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "claude.apiKey": "${localEnv:ANTHROPIC_API_KEY}",
        "noir.nargoPath": "/usr/local/bin/nargo"
      },
      "extensions": [
        "noir-lang.vscode-noir",
        "NomicFoundation.hardhat-solidity",
        "anthropic.claude-code"
      ]
    }
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  "workspaceFolder": "${localWorkspaceFolder}",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "HOME": "${localEnv:HOME}"
  }
}
